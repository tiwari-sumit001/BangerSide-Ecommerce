<%- include("./partials/header") %>

<div class="p-10 flex gap-12">
  <div class="flex flex-col gap-6">
    <% if (success && success.length > 0) { %>
      <div class="rounded-md bg-blue-500 px-4 py-2 text-white">
        <%= success %>
      </div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="rounded-md bg-red-500 px-4 py-2 text-white">
        <%= error %>
      </div>
    <% } %>

    <% if (cartItems.length === 0) { %>
      <div class="w-[320px] bg-white p-6 rounded-lg shadow">
        <h2 class="text-lg font-semibold mb-2">Your cart is empty</h2>
        <p class="text-sm text-gray-600 mb-4">Add products from the shop to continue building the order flow.</p>
        <a href="/shop" class="inline-block bg-black text-white px-4 py-2 rounded-md">Go to shop</a>
      </div>
    <% } %>

    <% if (cartItems.length > 0) { %>
      <div class="flex justify-end w-full max-w-[320px]">
        <a href="/cart/empty" class="text-sm font-semibold text-red-600 hover:text-red-800 transition-colors bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-md">
          Empty Cart
        </a>
      </div>
    <% } %>

    <% cartItems.forEach(function(item) { %>
      <div class="w-[320px] bg-gray-100 rounded-lg overflow-hidden shadow relative">
        <a href="/cart/remove/<%= item.productId %>" class="absolute top-2 right-2 bg-white/80 hover:bg-white text-red-500 p-1.5 rounded-full shadow-sm hover:shadow transition-all" title="Remove from cart">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        <div class="w-full h-64 bg-gray-200 flex items-center justify-center">
          <img
            class="h-full object-contain"
            src="<%= item.imageSrc %>"
          >
        </div>

        <div class="p-4 flex justify-between items-center bg-gray-200">
          <div>
            <h2 class="text-lg font-semibold"><%= item.productName %></h2>
            <div class="flex items-center gap-2 mt-1">
                <p class="text-xs text-gray-600"><%= item.productCategory %></p>
                <span class="px-2 py-0.5 bg-black text-white text-[9px] font-black rounded-md uppercase">Size: <%= item.size %></span>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <a href="/cart/decrease/<%= item.productId %>" class="px-2 py-1 bg-white rounded-full">-</a>
            <span><%= item.quantity %></span>
            <a href="/cart/increase/<%= item.productId %>" class="px-2 py-1 bg-white rounded-full">+</a>
          </div>
        </div>

        <div class="p-4 flex justify-between">
          <span>Net Total</span>
          <span>Rs. <%= item.lineTotal %></span>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="w-1/2 bg-white shadow rounded-xl p-8 h-fit">
    <h2 class="text-xl font-semibold mb-4">Price Breakdown</h2>

    <div class="space-y-2">
      <div class="flex justify-between">
        <span>Total MRP</span>
        <span>Rs. <%= totalMRP %></span>
      </div>

      <div class="flex justify-between">
        <span>Discount</span>
        <span>Rs. <%= discount %></span>
      </div>

      <div class="flex justify-between">
        <span>Platform Fee</span>
        <span>Rs. <%= platformFee %></span>
      </div>

      <div class="flex justify-between">
        <span>Shipping Fee</span>
        <span>FREE</span>
      </div>
    </div>

    <hr class="my-5">

    <div class="flex justify-between text-lg font-bold mb-6">
      <span>Total Amount</span>
      <span class="text-green-600">Rs. <%= finalAmount %></span>
    </div>

    <a href="/checkout" class="inline-block w-full text-center bg-black text-white px-4 py-3 rounded-md">
      Proceed to Checkout
    </a>
  </div>
</div>

<%- include("./partials/footer") %>
