<%- include("./partials/header") %>

<div class="max-w-5xl mx-auto px-6 py-10">
  <% if (success && success.length > 0) { %>
    <div class="mb-6 rounded-md bg-blue-500 px-4 py-2 text-white">
      <%= success %>
    </div>
  <% } %>

  <% if (error && error.length > 0) { %>
    <div class="mb-6 rounded-md bg-red-500 px-4 py-2 text-white">
      <%= error %>
    </div>
  <% } %>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-semibold">Your Orders</h1>
    <a href="/shop" class="text-sm bg-black text-white px-4 py-2 rounded-md">Continue Shopping</a>
  </div>

  <% if (orders.length === 0) { %>
    <div class="bg-white rounded-xl shadow p-8 text-center text-gray-600">
      You haven't placed any orders yet.
    </div>
  <% } %>

  <div class="space-y-6">
    <% orders.forEach(function(order) { %>
      <div class="bg-white rounded-xl shadow p-6">
        <div class="flex justify-between items-center mb-4">
          <div>
            <p class="text-sm text-gray-500">Order placed on</p>
            <p class="font-semibold"><%= new Date(order.createdAt).toDateString() %></p>
          </div>
          <div class="text-right">
            <p class="text-sm text-gray-500">Status</p>
            <p class="font-semibold capitalize"><%= order.orderStatus %></p>
          </div>
        </div>

        <div class="space-y-3 mb-4">
          <% order.items.forEach(function(item) { %>
            <div class="flex justify-between items-center text-sm border-b pb-3 mb-3">
              <div class="flex gap-3 items-center">
                <div class="w-12 h-12 shrink-0 bg-gray-100 rounded overflow-hidden">
                  <img src="<%= item.imageSrc %>" alt="<%= item.name %>" class="w-full h-full object-cover">
                </div>
                <div>
                  <p class="font-medium text-base"><%= item.name %></p>
                  <p class="text-gray-500 mt-0.5">Qty: <%= item.quantity %></p>
                </div>
              </div>
              <p class="font-semibold text-base">Rs. <%= (item.price - item.discount) * item.quantity %></p>
            </div>
          <% }) %>
        </div>

        <div class="grid grid-cols-2 gap-6 text-sm">
          <div>
            <p class="text-gray-500 mb-1">Delivery Address</p>
            <p><%= order.shippingAddress.fullName %></p>
            <p><%= order.shippingAddress.street %>, <%= order.shippingAddress.city %></p>
            <p><%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
          </div>

          <div class="text-right">
            <p class="text-gray-500 mb-1">Payment</p>
            <p><%= order.paymentMethodLabel %> / <%= order.paymentStatusLabel %></p>
            <p class="text-gray-500 capitalize">Gateway: <%= order.paymentGateway || "offline" %></p>
            <p class="font-semibold mt-2">Total: Rs. <%= order.pricing.finalAmount %></p>
          </div>
        </div>

        <div class="mt-5 flex items-center justify-between">
          <div class="flex gap-2 text-xs">
            <span class="px-3 py-1 rounded-full <%= order.orderStatus === 'placed' ? 'bg-black text-white' : 'bg-gray-200 text-gray-700' %>">Placed</span>
            <span class="px-3 py-1 rounded-full <%= order.orderStatus === 'packed' ? 'bg-black text-white' : 'bg-gray-200 text-gray-700' %>">Packed</span>
            <span class="px-3 py-1 rounded-full <%= order.orderStatus === 'shipped' ? 'bg-black text-white' : 'bg-gray-200 text-gray-700' %>">Shipped</span>
            <span class="px-3 py-1 rounded-full <%= order.orderStatus === 'delivered' ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700' %>">Delivered</span>
            <span class="px-3 py-1 rounded-full <%= order.orderStatus === 'cancelled' ? 'bg-red-500 text-white' : 'bg-gray-200 text-gray-700' %>">Cancelled</span>
          </div>

          <% if (['placed', 'packed'].includes(order.orderStatus)) { %>
            <form action="/orders/<%= order._id %>/cancel" method="post">
              <button class="bg-red-500 text-white px-4 py-2 rounded-md text-sm">
                Cancel Order
              </button>
            </form>
          <% } %>
        </div>

        <div class="mt-4">
          <a href="/orders/<%= order._id %>" class="text-sm text-blue-600 hover:underline">View full details</a>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include("./partials/footer") %>
