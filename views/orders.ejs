<%- include("./partials/header") %>

<div class="max-w-screen-xl mx-auto px-6 md:px-10 py-8 md:py-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-zinc-900 tracking-tighter uppercase italic">Your <span class="text-blue-600">Orders</span></h1>
            <p class="text-zinc-400 text-xs md:text-sm font-medium mt-2 tracking-wide">Track your premium acquisitions and history.</p>
        </div>
        <a href="/shop" class="w-fit bg-black text-white px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-xl shadow-black/20">
            Continue Shopping
        </a>
    </div>

    <% if (success && success.length > 0) { %>
        <div class="mb-8 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 px-6 py-4 rounded-2xl text-center font-bold text-xs uppercase tracking-widest animate-bounce-short">
            <%= success %>
        </div>
    <% } %>

    <% if (error && error.length > 0) { %>
        <div class="mb-8 bg-rose-500/10 border border-rose-500/20 text-rose-600 px-6 py-4 rounded-2xl text-center font-bold text-xs uppercase tracking-widest">
            <%= error %>
        </div>
    <% } %>

    <% if (orders.length === 0) { %>
        <div class="bg-white rounded-[3rem] shadow-xl p-16 md:p-24 text-center border border-zinc-100 flex flex-col items-center">
            <div class="w-20 h-20 bg-zinc-50 rounded-full flex items-center justify-center mb-8 text-4xl shadow-inner">📦</div>
            <h2 class="text-xl md:text-2xl font-black text-zinc-900 mb-2 uppercase tracking-tight">No Orders Yet</h2>
            <p class="text-zinc-400 text-xs md:text-sm max-w-sm leading-relaxed mb-10 font-medium">You haven't placed any orders yet. Let's start your journey with our fresh drops.</p>
            <a href="/shop" class="bg-black text-white px-10 py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-2xl shadow-black/20 hover:-translate-y-1 active:scale-95 transition-all">
                Explore Shop
            </a>
        </div>
    <% } else { %>
        <div class="space-y-8">
            <% orders.forEach(function(order) { %>
                <div class="bg-white rounded-[2.5rem] border border-zinc-100 shadow-sm overflow-hidden group">
                    <div class="p-8 md:p-10">
                        <!-- Order Header -->
                        <div class="flex flex-col md:flex-row justify-between md:items-center gap-6 mb-10 pb-10 border-b border-zinc-50">
                            <div class="flex items-center gap-6">
                                <div class="w-16 h-16 bg-zinc-50 rounded-2xl flex items-center justify-center text-xl shadow-inner group-hover:rotate-6 transition-transform">🛍️</div>
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-1">Placed On</p>
                                    <p class="text-lg font-black text-zinc-900"><%= new Date(order.createdAt).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                </div>
                            </div>
                            <div class="flex flex-col md:items-end gap-2">
                                <span class="px-5 py-2 bg-zinc-900 text-white rounded-full text-[10px] font-black uppercase tracking-widest">
                                    <%= order.orderStatus %>
                                </span>
                                <p class="text-[9px] font-black text-zinc-400 uppercase tracking-widest">Order ID: #<%= order._id.toString().slice(-8).toUpperCase() %></p>
                            </div>
                        </div>

                        <!-- Items -->
                        <div class="space-y-6 mb-10">
                            <% order.items.forEach(function(item) { %>
                                <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-6 p-6 bg-zinc-50 rounded-3xl border border-zinc-100">
                                    <div class="flex gap-6 items-center">
                                        <div class="w-20 h-24 bg-white rounded-2xl overflow-hidden shadow-sm shrink-0">
                                            <img src="<%= item.imageSrc %>" class="w-full h-full object-cover">
                                        </div>
                                        <div>
                                            <h3 class="text-lg font-black text-zinc-900 tracking-tight leading-tight mb-1"><%= item.name %></h3>
                                            <div class="flex items-center gap-2">
                                                <span class="text-[9px] font-black uppercase tracking-widest text-zinc-400">Qty: <%= item.quantity %></span>
                                                <span class="w-1 h-1 bg-zinc-200 rounded-full"></span>
                                                <span class="text-[9px] font-black uppercase tracking-widest text-zinc-400">Size: <%= item.size || 'M' %></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-left sm:text-right">
                                        <p class="text-xl font-black text-zinc-900">₹<%= (item.price - item.discount) * item.quantity %></p>
                                        <p class="text-[9px] font-black text-zinc-400 uppercase tracking-widest mt-1">Item Total</p>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <!-- Bottom Info -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-4">
                            <div class="bg-zinc-50 p-6 rounded-3xl border border-zinc-100">
                                <p class="text-[9px] font-black uppercase tracking-widest text-zinc-400 mb-3">Delivery Address</p>
                                <p class="text-xs font-black text-zinc-900 mb-1"><%= order.shippingAddress.fullName %></p>
                                <p class="text-[11px] text-zinc-500 font-medium leading-relaxed">
                                    <%= order.shippingAddress.street %>, <%= order.shippingAddress.city %><br>
                                    <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %>
                                </p>
                            </div>

                            <div class="bg-zinc-50 p-6 rounded-3xl border border-zinc-100">
                                <p class="text-[9px] font-black uppercase tracking-widest text-zinc-400 mb-3">Payment Stats</p>
                                <div class="space-y-2">
                                    <p class="text-xs font-bold text-zinc-900 uppercase tracking-wide">Method: <%= order.paymentMethodLabel %></p>
                                    <p class="text-[11px] font-black <%= order.paymentStatus === 'paid' ? 'text-emerald-500' : 'text-orange-500' %> uppercase tracking-widest"><%= order.paymentStatusLabel %></p>
                                    <p class="text-[9px] text-zinc-400 font-medium">Gateway: <%= order.paymentGateway || "N/A" %></p>
                                </div>
                            </div>

                            <div class="bg-black p-8 rounded-[2rem] text-white flex flex-col justify-between shadow-xl shadow-black/20">
                                <div>
                                    <p class="text-[9px] font-black uppercase tracking-widest text-zinc-500 mb-2">Total Amount Paid</p>
                                    <p class="text-4xl font-black tracking-tighter text-blue-500">₹<%= order.pricing.finalAmount %></p>
                                </div>
                                <div class="mt-8 flex justify-between items-center">
                                    <a href="/orders/<%= order._id %>" class="text-[9px] font-black uppercase tracking-widest text-white/60 hover:text-white transition-all underline underline-offset-4">Order Details</a>
                                    <% if (['placed', 'packed'].includes(order.orderStatus)) { %>
                                        <form action="/orders/<%= order._id %>/cancel" method="post" onsubmit="return confirm('Archive this order?')">
                                            <button class="text-[9px] font-black uppercase tracking-widest text-rose-500 hover:text-rose-400 transition-all">Cancel</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include("./partials/footer") %>
