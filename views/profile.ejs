<%- include('./partials/header') %>

<div class="max-w-screen-xl mx-auto px-10 py-16">
  <!-- Profile Header -->
  <div class="flex flex-col md:flex-row items-center gap-10 mb-16">
    <div class="relative">
      <div class="w-40 h-40 bg-gradient-to-tr from-blue-600 to-purple-600 rounded-[3rem] flex items-center justify-center text-5xl font-black text-white shadow-2xl shadow-blue-500/30">
        <%= user.fullname.charAt(0) %>
      </div>
      <div class="absolute -bottom-2 -right-2 bg-white dark:bg-zinc-900 p-3 rounded-2xl shadow-xl border border-zinc-100 dark:border-zinc-800">
        <span class="text-xl">🛡️</span>
      </div>
    </div>

    <div class="text-center md:text-left">
      <div class="flex flex-col md:flex-row items-center gap-4 mb-2">
        <h1 class="text-4xl font-black tracking-tighter uppercase text-zinc-900 dark:text-white"><%= user.fullname %></h1>
        <span class="bg-blue-600 text-white px-4 py-1.5 rounded-full text-[10px] font-black tracking-widest uppercase">PRO MEMBER</span>
      </div>
      <p class="text-zinc-400 font-medium mb-6"><%= user.email %></p>
      
      <div class="flex flex-wrap justify-center md:justify-start gap-3">
        <a href="/orders" class="bg-black text-white px-8 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-xl shadow-black/10">My Orders</a>
        <a href="/wishlist" class="bg-white dark:bg-zinc-800 border border-zinc-100 dark:border-zinc-700 px-8 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-zinc-50 transition-all">Wishlist</a>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
    <div class="bg-white dark:bg-zinc-900 p-10 rounded-[2.5rem] border border-zinc-100 dark:border-zinc-800 shadow-sm">
      <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-4">Total Orders</p>
      <p class="text-5xl font-black text-zinc-900 dark:text-white"><%= user.orders ? user.orders.length : 0 %></p>
    </div>
    <div class="bg-white dark:bg-zinc-900 p-10 rounded-[2.5rem] border border-zinc-100 dark:border-zinc-800 shadow-sm">
      <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-4">Addresses</p>
      <p class="text-5xl font-black text-zinc-900 dark:text-white"><%= user.addresses ? user.addresses.length : 0 %></p>
    </div>
    <div class="bg-white dark:bg-zinc-900 p-10 rounded-[2.5rem] border border-zinc-100 dark:border-zinc-800 shadow-sm">
      <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-4">Member Since</p>
      <p class="text-xl font-bold text-zinc-900 dark:text-white"><%= new Date(user.createdAt).getFullYear() %></p>
    </div>
  </div>

  <!-- Settings/Actions -->
  <div class="bg-zinc-100/50 dark:bg-zinc-900/50 p-12 rounded-[3rem] border border-zinc-200 dark:border-zinc-800">
    <h3 class="text-xl font-black uppercase tracking-tighter mb-8 text-zinc-900 dark:text-white">Security & Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <button class="flex items-center justify-between p-6 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 hover:border-black transition-all group">
        <span class="text-sm font-bold text-zinc-600 dark:text-zinc-400 group-hover:text-black">Change Password</span>
        <span class="text-zinc-300">→</span>
      </button>
      <button class="flex items-center justify-between p-6 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-100 dark:border-zinc-800 hover:border-black transition-all group">
        <span class="text-sm font-bold text-zinc-600 dark:text-zinc-400 group-hover:text-black">Two-Factor Auth</span>
        <span class="bg-emerald-500/10 text-emerald-500 px-3 py-1 rounded-full text-[8px] font-black uppercase">ACTIVE</span>
      </button>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
