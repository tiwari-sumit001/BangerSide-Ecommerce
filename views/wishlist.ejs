<%- include("./partials/header") %>

<div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-8 md:py-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-4">
        <div>
            <h1 class="text-4xl md:text-5xl font-black text-zinc-900 tracking-tighter uppercase italic">Your <span class="text-rose-500">Wishlist</span></h1>
            <p class="text-zinc-400 text-xs md:text-sm font-medium mt-2 tracking-wide">Saved items for your next premium acquisition.</p>
        </div>
        <% if (user.wishlist && user.wishlist.length > 0) { %>
            <a href="/wishlist/empty" class="w-fit px-6 py-3 bg-rose-50 text-rose-500 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-rose-500 hover:text-white transition-all shadow-sm">
                Empty Wishlist
            </a>
        <% } %>
    </div>

    <% if (success && success.length > 0) { %>
        <div class="mb-8 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 px-6 py-4 rounded-2xl text-center font-bold text-xs uppercase tracking-widest animate-bounce-short">
            <%= success %>
        </div>
    <% } %>

    <% if (error && error.length > 0) { %>
        <div class="mb-8 bg-rose-500/10 border border-rose-500/20 text-rose-600 px-6 py-4 rounded-2xl text-center font-bold text-xs uppercase tracking-widest">
            <%= error %>
        </div>
    <% } %>

    <% if (!user.wishlist || user.wishlist.length === 0) { %>
        <div class="bg-white rounded-[3rem] shadow-xl p-16 md:p-24 text-center border border-zinc-100 flex flex-col items-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-zinc-50 rounded-full flex items-center justify-center mb-8 text-4xl shadow-inner">💖</div>
            <h2 class="text-xl md:text-2xl font-black text-zinc-900 mb-2 uppercase tracking-tight">Your Wishlist is Empty</h2>
            <p class="text-zinc-400 text-xs md:text-sm max-w-sm leading-relaxed mb-10 font-medium">Keep track of items you love. They'll wait for you here until you're ready to make them yours.</p>
            <a href="/shop" class="bg-black text-white px-10 py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-2xl shadow-black/20 hover:-translate-y-1 active:scale-95 transition-all">
                Explore the Collection
            </a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
            <% user.wishlist.forEach(function(item) { %>
                <% if (item && item.product) { %>
                    <% let product = item.product; %>
                    <div class="group bg-white rounded-[2rem] md:rounded-[2.5rem] shadow-sm hover:shadow-2xl transition-all duration-500 border border-transparent hover:border-gray-100 overflow-hidden relative">
                        <!-- Product Visual -->
                        <div class="h-64 md:h-72 w-full relative overflow-hidden" style="background-color: <%= product.bgcolor || '#f3f4f6' %>;">
                            <% let img = product.image 
                                ? "data:image/jpeg;base64," + product.image.toString('base64')
                                : "https://via.placeholder.com/300"; %>
                            <img class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110" src="<%= img %>">
                            
                            <!-- Remove Button Overlay -->
                            <a href="/wishlist/remove/<%= product._id %>" class="absolute top-4 right-4 md:top-6 md:right-6 z-20 w-10 h-10 bg-white/80 backdrop-blur rounded-xl flex items-center justify-center text-rose-500 opacity-0 group-hover:opacity-100 transition-all hover:scale-110">
                                <i class="ri-close-line text-xl font-bold"></i>
                            </a>
                        </div>

                        <!-- Content -->
                        <div class="p-6 md:p-8">
                            <div class="flex items-center justify-between mb-4">
                                <span class="px-3 py-1 bg-zinc-100 rounded-full text-[8px] md:text-[9px] font-black uppercase text-zinc-400 tracking-wider"><%= product.category %></span>
                                <% if (item.size) { %>
                                    <span class="text-[8px] md:text-[9px] font-black bg-black text-white px-2 py-1 rounded-full uppercase tracking-wider">Size: <%= item.size %></span>
                                <% } %>
                            </div>

                            <h2 class="text-lg md:text-xl font-black text-zinc-900 tracking-tight mb-4 truncate"><%= product.name %></h2>
                            
                            <div class="flex items-center justify-between mb-6 md:mb-8">
                                <div class="text-left">
                                    <p class="text-[8px] md:text-[9px] font-black text-zinc-400 uppercase tracking-widest mb-1">Elite Price</p>
                                    <p class="text-xl md:text-2xl font-black text-black">₹<%= product.price - (product.discount || 0) %></p>
                                </div>
                            </div>

                            <!-- Move to Cart -->
                            <a href="/addtocart/<%= product._id %>?size=<%= item.size || 'M' %>" class="w-full bg-zinc-900 text-white py-4 rounded-2xl flex items-center justify-center gap-3 text-[9px] md:text-[10px] font-black uppercase tracking-[0.2em] hover:bg-blue-600 hover:shadow-xl hover:shadow-blue-600/20 active:scale-95 transition-all">
                                <i class="ri-shopping-bag-3-fill text-sm"></i>
                                Move to Bag
                            </a>
                        </div>
                    </div>
                <% } %>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include("./partials/footer") %>
