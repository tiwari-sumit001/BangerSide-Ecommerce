<%- include("./partials/header") %>

<div class="max-w-screen-2xl mx-auto px-8 py-10 flex gap-10">
    <!-- Sidebar Filters -->
    <div class="w-1/4 sticky top-10 h-fit bg-white/80 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-gray-100">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold bg-gradient-to-r from-black to-gray-600 bg-clip-text text-transparent">Filters</h2>
            <a href="/shop" class="text-xs font-medium text-blue-600 hover:underline">Clear All</a>
        </div>

        <form action="/shop" method="get" class="space-y-8">
            <!-- Search -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Search</label>
                <input type="text" name="search" value="<%= filters.search %>" placeholder="Find your style..." 
                    class="w-full bg-gray-50 border-0 rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-black transition-all">
            </div>

            <!-- Price Range -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-3">Price Range (Rs.)</label>
                <div class="flex items-center gap-3">
                    <input type="number" name="minPrice" value="<%= filters.minPrice %>" placeholder="Min" step="100"
                        class="w-1/2 bg-gray-50 border-0 rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-black">
                    <span class="text-gray-400">-</span>
                    <input type="number" name="maxPrice" value="<%= filters.maxPrice %>" placeholder="Max" step="100"
                        class="w-1/2 bg-gray-50 border-0 rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-black">
                </div>
            </div>

            <!-- Gender -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-3">Gender</label>
                <div class="grid grid-cols-1 gap-2">
                    <% ["Men", "Women", "Unisex"].forEach(g => { %>
                        <label class="flex items-center gap-3 group cursor-pointer">
                            <input type="radio" name="gender" value="<%= g %>" <%= filters.gender === g ? "checked" : "" %> 
                                class="w-4 h-4 text-black focus:ring-black border-gray-300">
                            <span class="text-sm text-gray-600 group-hover:text-black transition-colors"><%= g %></span>
                        </label>
                    <% }) %>
                </div>
            </div>

            <!-- Sort By -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Sort By</label>
                <select name="sort" class="w-full bg-gray-50 border-0 rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-black">
                    <option value="newest" <%= filters.sort === "newest" ? "selected" : "" %>>Newest First</option>
                    <option value="low-to-high" <%= filters.sort === "low-to-high" ? "selected" : "" %>>Price: Low to High</option>
                    <option value="high-to-low" <%= filters.sort === "high-to-low" ? "selected" : "" %>>Price: High to Low</option>
                </select>
            </div>

            <button class="w-full bg-black text-white rounded-2xl py-4 font-bold shadow-lg hover:shadow-black/20 hover:-translate-y-0.5 transition-all active:scale-95">
                Apply Filters
            </button>
        </form>
    </div>

    <!-- Product Grid -->
    <div class="w-3/4">
        <!-- AI Mood Search -->
        <div class="mb-12 relative">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-purple-600 rounded-[2.5rem] blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
            <div class="relative bg-white rounded-[2.5rem] p-8 border border-zinc-100 shadow-sm overflow-hidden">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h2 class="text-xl font-black uppercase tracking-widest text-zinc-900">BANGER AI <span class="text-blue-600">Mood Search</span></h2>
                        <p class="text-xs text-zinc-400 font-medium">Type your vibe (e.g. "College first day" or "Rooftop Party")</p>
                    </div>
                    <div class="w-12 h-12 bg-black text-white rounded-2xl flex items-center justify-center shadow-lg shadow-black/20">✨</div>
                </div>
                <div class="relative">
                    <input type="text" id="vibe-search-input" 
                        placeholder="What's the vibe today?..." 
                        class="w-full bg-zinc-50 border-none rounded-2xl px-8 pr-32 py-5 text-sm font-medium focus:ring-2 focus:ring-black transition-all outline-none">
                    <div class="absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-2">
                        <button onclick="searchByVibe()" class="bg-black text-white px-8 py-3 rounded-xl text-xs font-bold hover:scale-105 active:scale-95 transition-all">
                            MATCH VIBE
                        </button>
                    </div>
                </div>
                <div class="mt-4 flex gap-2 overflow-x-auto no-scrollbar">
                    <button onclick="setVibe('Midnight City')" class="px-4 py-2 rounded-full border border-zinc-100 text-[10px] font-bold text-zinc-500 hover:border-black hover:text-black transition-all whitespace-nowrap">🌃 Midnight City</button>
                    <button onclick="setVibe('Sun-Kissed Brunch')" class="px-4 py-2 rounded-full border border-zinc-100 text-[10px] font-bold text-zinc-500 hover:border-black hover:text-black transition-all whitespace-nowrap">🥞 Sun-Kissed Brunch</button>
                    <button onclick="setVibe('Cyberpunk Street')" class="px-4 py-2 rounded-full border border-zinc-100 text-[10px] font-bold text-zinc-500 hover:border-black hover:text-black transition-all whitespace-nowrap">🌆 Cyberpunk Street</button>
                    <button onclick="setVibe('Zen Workspace')" class="px-4 py-2 rounded-full border border-zinc-100 text-[10px] font-bold text-zinc-500 hover:border-black hover:text-black transition-all whitespace-nowrap">🧘 Zen Workspace</button>
                </div>

                <!-- AI Stylist Response Area -->
                <div id="ai-response-area" class="mt-8 pt-8 border-t border-zinc-50 hidden animate-fade-in">
                    <div class="flex gap-6 items-start">
                        <div class="w-12 h-12 bg-black text-white rounded-2xl flex items-center justify-center shrink-0 shadow-lg shadow-black/20 text-xl">✨</div>
                        <div class="flex-1">
                            <h3 class="text-xs font-black uppercase tracking-widest text-zinc-400 mb-2">Stylist's Note</h3>
                            <p id="ai-advice-text" class="text-sm font-medium text-zinc-800 leading-relaxed mb-4"></p>
                            <div class="bg-blue-50/50 p-4 rounded-2xl border border-blue-100/50">
                                <p id="ai-pairing-text" class="text-[11px] font-bold text-blue-700"></p>
                            </div>
                        </div>
                    </div>
                    
                    <div id="ai-product-results" class="grid grid-cols-3 gap-6 mt-8">
                        <!-- AI recommended products -->
                    </div>
                    
                    <button onclick="clearAIResults()" class="mt-8 text-[10px] font-black uppercase tracking-widest text-zinc-300 hover:text-black transition-all flex items-center gap-2">
                        <span>✕</span> Clear AI Recommendations
                    </button>
                </div>
            </div>
        </div>

        <!-- Messages -->
        <% if (success && success.length > 0) { %>
            <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 px-6 py-4 rounded-2xl text-center font-medium animate-bounce-short">
                <%= success %>
            </div>
        <% } %>

        <% if (error && error.length > 0) { %>
            <div class="mb-6 bg-rose-500/10 border border-rose-500/20 text-rose-600 px-6 py-4 rounded-2xl text-center font-medium">
                <%= error %>
            </div>
        <% } %>

        <% if (products.length === 0) { %>
            <div class="bg-white rounded-3xl shadow-xl p-20 text-center flex flex-col items-center border border-gray-100">
                <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mb-6">
                    <span class="text-4xl">🔍</span>
                </div>
                <h3 class="text-xl font-bold text-gray-800 mb-2">No products found</h3>
                <p class="text-gray-500">Try adjusting your filters or search terms.</p>
                <a href="/shop" class="mt-6 text-blue-600 font-semibold">View All Products</a>
            </div>
        <% } %>

        <div class="grid grid-cols-3 gap-10">
            <% products.forEach(function(product) { %>
                <div class="group bg-white rounded-[2.5rem] shadow-sm hover:shadow-2xl transition-all duration-500 border border-transparent hover:border-gray-100 overflow-hidden relative">
                    
                    <!-- Elite Stock Badge -->
                    <% if (product.quantity < 15) { %>
                        <div class="absolute top-6 left-6 z-30 bg-orange-500 text-white px-4 py-1.5 rounded-full text-[9px] font-black animate-pulse shadow-lg shadow-orange-500/40 uppercase tracking-widest">
                            🔥 Only <%= product.quantity %> Left
                        </div>
                    <% } %>

                    <!-- Product Image Slider -->
                    <div class="h-72 w-full relative overflow-hidden group/slider"
                        style="background-color: <%= product.bgcolor || '#f3f4f6' %>;">
                        
                        <div class="flex h-full w-full overflow-x-auto snap-x snap-mandatory no-scrollbar scroll-smooth">
                            <% if (product.images && product.images.length > 0) { %>
                                <% product.images.forEach((imgBuffer, index) => { %>
                                    <div class="h-full w-full shrink-0 snap-center relative">
                                        <img class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110" 
                                             src="data:image/jpeg;base64,<%= imgBuffer.toString('base64') %>" />
                                        
                                        <!-- Angle Indicator Dots -->
                                        <% if (product.images.length > 1) { %>
                                            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1.5 opacity-0 group-hover/slider:opacity-100 transition-opacity duration-300">
                                                <% product.images.forEach((_, i) => { %>
                                                    <div class="w-1.5 h-1.5 rounded-full <%= i === index ? 'bg-black w-3' : 'bg-black/20' %> transition-all"></div>
                                                <% }) %>
                                            </div>
                                        <% } %>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="h-full w-full shrink-0">
                                    <img class="h-full w-full object-cover" 
                                         src="data:image/jpeg;base64,<%= product.image ? product.image.toString('base64') : '' %>" />
                                </div>
                            <% } %>
                        </div>
                        
                        <!-- Quick Action Overlay -->
                        <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center gap-4 z-20">
                            <a id="add-to-wishlist-<%= product._id %>" 
                                href="/wishlist/add/<%= product._id %>" 
                                onclick="return handleWishlistClick(this, '<%= product._id %>')"
                                class="w-14 h-14 bg-white rounded-3xl flex items-center justify-center text-rose-500 shadow-2xl hover:scale-110 active:scale-95 transition-all text-2xl">
                                <i class="ri-heart-fill"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Details -->
                    <div class="p-8">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <span class="text-[10px] uppercase tracking-widest font-bold text-gray-400 mb-1 block"><%= product.gender %> | <%= product.category %></span>
                                <h3 class="font-bold text-xl text-gray-800 leading-tight"><%= product.name %></h3>
                            </div>
                            <div class="text-right">
                                <p class="font-black text-xl text-black">₹<%= product.price - (product.discount || 0) %></p>
                                <% if (product.discount > 0) { %>
                                    <p class="text-xs text-gray-400 line-through">₹<%= product.price %></p>
                                <% } %>
                            </div>
                        </div>

                        <div class="flex items-center justify-between mt-8">
                            <div class="flex gap-1.5 size-selector" data-product-id="<%= product._id %>">
                                <% (product.sizes || ["S", "M", "L", "XL"]).forEach(s => { %>
                                    <button onclick="selectSize(this, '<%= s %>', '<%= product._id %>')" 
                                        class="w-8 h-8 rounded-lg border border-gray-100 flex items-center justify-center text-[10px] font-bold text-gray-400 hover:border-black hover:text-black transition-all cursor-pointer bg-white">
                                        <%= s %>
                                    </button>
                                <% }) %>
                            </div>
                            
                            <a id="add-to-cart-<%= product._id %>" 
                                href="/addtocart/<%= product._id %>" 
                                onclick="return checkSizeSelected('<%= product._id %>')"
                                class="bg-black text-white px-6 py-3 rounded-2xl text-xs font-bold hover:scale-105 active:scale-95 transition-all shadow-lg shadow-black/10">
                                ADD TO CART
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
    const selectedSizes = {};

    function setVibe(vibe) {
        document.getElementById('vibe-search-input').value = vibe;
        searchByVibe();
    }

    async function searchByVibe() {
        const vibe = document.getElementById('vibe-search-input').value.trim();
        if (!vibe) return;

        const btn = document.querySelector('button[onclick="searchByVibe()"]');
        const originalText = btn.innerText;
        btn.innerText = 'CURATING...';
        btn.disabled = true;

        try {
            const response = await fetch('/ai/stylist', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: vibe })
            });
            const data = await response.json();

            document.getElementById('ai-advice-text').innerText = data.reply;
            document.getElementById('ai-pairing-text').innerText = data.pairing;

            const productContainer = document.getElementById('ai-product-results');
            productContainer.innerHTML = '';

            data.products.forEach(p => {
                const imgHtml = p.image
                    ? `<img src="data:image/jpeg;base64,${p.image}" class="w-full h-full object-cover group-hover/item:scale-110 transition-transform duration-700" />`
                    : `<div class="w-full h-full bg-zinc-100 flex items-center justify-center text-2xl opacity-20">👕</div>`;

                const productHtml = `
                    <div class="bg-zinc-50 rounded-3xl p-4 border border-zinc-100 hover:shadow-xl transition-all group/item animate-fade-in relative overflow-hidden">
                        <div class="absolute top-6 right-6 z-20 bg-blue-600 text-white px-3 py-1.5 rounded-xl text-[9px] font-black shadow-lg shadow-blue-600/20">
                            ✨ ${p.vibeScore}% MATCH
                        </div>
                        <div class="h-40 w-full bg-white rounded-2xl mb-4 overflow-hidden relative">
                            ${imgHtml}
                            <div class="absolute top-2 left-2 bg-black text-white px-2 py-1 rounded-full text-[8px] font-black uppercase tracking-tighter">AI PICK</div>
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-1">${p.category}</p>
                        <h4 class="text-sm font-bold text-zinc-900 truncate mb-2">${p.name}</h4>
                        <div class="mb-4 bg-white/50 p-2.5 rounded-xl border border-dashed border-zinc-200">
                            <p class="text-[9px] text-zinc-500 font-medium leading-tight italic">"${p.reason}"</p>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-black text-blue-600">₹${p.price}</span>
                            <a href="/shop?search=${encodeURIComponent(p.name)}" class="text-[9px] font-black uppercase tracking-widest text-zinc-900 hover:underline">View</a>
                        </div>
                    </div>`;
                productContainer.innerHTML += productHtml;
            });

            document.getElementById('ai-response-area').classList.remove('hidden');
            document.getElementById('ai-response-area').scrollIntoView({ behavior: 'smooth', block: 'center' });

        } catch (err) {
            alert('AI Stylist is offline. Try again later.');
        } finally {
            btn.innerText = originalText;
            btn.disabled = false;
        }
    }

    function clearAIResults() {
        document.getElementById('ai-response-area').classList.add('hidden');
        document.getElementById('vibe-search-input').value = '';
    }

    function selectSize(btn, size, productId) {
        const container = btn.parentElement;
        container.querySelectorAll('button').forEach(b => {
            b.classList.remove('bg-black', 'text-white', 'border-black');
            b.classList.add('bg-white', 'text-gray-400', 'border-gray-100');
        });
        btn.classList.remove('bg-white', 'text-gray-400', 'border-gray-100');
        btn.classList.add('bg-black', 'text-white', 'border-black');
        selectedSizes[productId] = size;
        
        // Update Cart Link
        const cartLink = document.getElementById(`add-to-cart-${productId}`);
        if (cartLink) cartLink.href = `/addtocart/${productId}?size=${size}`;
        
        // Update Wishlist Link
        const wishlistLink = document.getElementById(`add-to-wishlist-${productId}`);
        if (wishlistLink) wishlistLink.href = `/wishlist/add/${productId}?size=${size}`;
    }

    function checkSizeSelected(productId) {
        if (!selectedSizes[productId]) {
            const firstSizeBtn = document.querySelector(`.size-selector[data-product-id="${productId}"] button`);
            if (firstSizeBtn) {
                firstSizeBtn.click();
                return true; 
            }
        }
        return true;
    }

    function handleWishlistClick(el, productId) {
        if (!selectedSizes[productId]) {
            const firstSizeBtn = document.querySelector(`.size-selector[data-product-id="${productId}"] button`);
            if (firstSizeBtn) {
                firstSizeBtn.click();
                el.href = `/wishlist/add/${productId}?size=${selectedSizes[productId]}`;
            }
        }
        triggerConfetti();
        animateWishlist(el);
        return true;
    }

    function animateWishlist(el) {
        for (let i = 0; i < 6; i++) {
            const heart = document.createElement('span');
            heart.innerText = '❤';
            heart.className = 'absolute text-rose-500 animate-ping pointer-events-none';
            heart.style.left = (Math.random() * 40 - 20) + 'px';
            heart.style.top = (Math.random() * 40 - 20) + 'px';
            el.appendChild(heart);
            setTimeout(() => heart.remove(), 1000);
        }
    }

    function triggerConfetti() {
        confetti({
            particleCount: 150,
            spread: 70,
            origin: { y: 0.6 },
            colors: ['#2563eb', '#000000', '#ffffff']
        });
    }
</script>


<%- include("./partials/footer") %>
