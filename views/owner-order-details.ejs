<%- include('partials/header') %>

<div class="min-h-screen bg-zinc-50 flex font-['Outfit']">
  <!-- Admin Sidebar -->
  <div class="w-1/5 bg-white border-r border-zinc-200 p-10 flex flex-col justify-between sticky top-0 h-screen">
    <div>
        <div class="flex items-center gap-3 mb-12">
            <div class="w-10 h-10 bg-black rounded-2xl flex items-center justify-center text-white font-bold italic shadow-lg shadow-black/20">S.</div>
            <h2 class="font-black text-xl tracking-tighter">BANGER SIDE.ADMIN</h2>
        </div>
        
        <nav class="space-y-2">
            <a href="/owners/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Dashboard</span>
            </a>
            <a href="/owners/admin" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Create New Product</span>
            </a>
            <a href="/owners/products" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Manage Inventory</span>
            </a>
            <a href="/owners/orders" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-bold bg-black text-white shadow-xl shadow-black/10">
                <span>Orders Log</span>
            </a>
        </nav>
    </div>

    <a href="/owners/logout" class="px-4 py-3 rounded-2xl text-sm font-bold text-rose-500 hover:bg-rose-50 transition-all">
        Logout System
    </a>
  </div>

  <!-- Main Content -->
  <div class="flex-1 p-16">
    <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-12">
            <div>
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-2">Detailed Breakdown</p>
                <h1 class="text-4xl font-black text-zinc-900 tracking-tight">Order #<%= order._id.toString().slice(-8).toUpperCase() %></h1>
            </div>
            <a href="/owners/orders" class="px-8 py-4 bg-zinc-200 rounded-[2rem] text-xs font-black hover:bg-zinc-300 transition-all uppercase tracking-widest">BACK TO LIST</a>
        </div>

        <div class="grid grid-cols-3 gap-10">
            <!-- Left: Order Summary & Items -->
            <div class="col-span-2 space-y-10">
                <!-- Status Bar -->
                <div class="bg-black p-10 rounded-[3rem] shadow-2xl shadow-black/10 flex justify-between items-center">
                    <div>
                        <p class="text-[10px] font-black uppercase text-zinc-500 tracking-widest mb-1">Payment</p>
                        <p class="text-lg font-bold text-white"><%= order.paymentStatusLabel %></p>
                    </div>
                    <div class="w-px h-10 bg-zinc-800"></div>
                    <div>
                        <p class="text-[10px] font-black uppercase text-zinc-500 tracking-widest mb-1">Method</p>
                        <p class="text-lg font-bold text-white"><%= order.paymentMethodLabel %></p>
                    </div>
                    <div class="w-px h-10 bg-zinc-800"></div>
                    <div>
                        <p class="text-[10px] font-black uppercase text-zinc-500 tracking-widest mb-1">Full Value</p>
                        <p class="text-3xl font-black text-blue-400">₹<%= order.pricing.finalAmount %></p>
                    </div>
                </div>

                <!-- Items -->
                <div class="bg-white p-10 rounded-[2.5rem] border border-zinc-100 shadow-sm">
                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-10 flex items-center gap-3">
                        <span class="w-2 h-2 bg-black rounded-full"></span> Line Items
                    </h3>

                    <div class="space-y-6">
                        <% order.items.forEach(function(item) { %>
                            <div class="flex items-center justify-between p-6 bg-zinc-50 rounded-[2rem] group hover:bg-white hover:shadow-xl hover:shadow-black/5 transition-all border border-transparent hover:border-zinc-100">
                                <div class="flex items-center gap-6">
                                    <div class="w-20 h-20 bg-white rounded-3xl overflow-hidden shadow-sm flex items-center justify-center">
                                        <img src="<%= item.imageSrc %>" class="w-full h-full object-cover">
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-zinc-900"><%= item.name %></h4>
                                        <p class="text-xs text-zinc-400 mt-1 font-medium italic">SKU: <%= item.product.toString().slice(-6).toUpperCase() %></p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-12">
                                    <div class="text-center">
                                        <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest">Qty</p>
                                        <p class="font-black text-black"><%= item.quantity %></p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest">Subtotal</p>
                                        <p class="text-xl font-black text-black">₹<%= (item.price - item.discount) * item.quantity %></p>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- Right: Customer & Management -->
            <div class="space-y-10">
                <!-- Customer -->
                <div class="bg-white p-10 rounded-[2.5rem] border border-zinc-100 shadow-sm">
                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-8">Shipping Detail</h3>
                    
                    <div class="p-6 bg-zinc-900 rounded-3xl text-white">
                        <p class="text-lg font-black italic tracking-tight"><%= order.shippingAddress.fullName %></p>
                        <p class="text-zinc-400 text-xs mt-1"><%= order.shippingAddress.phone %></p>
                        <div class="mt-6 pt-6 border-t border-zinc-800 space-y-2">
                            <p class="text-xs text-zinc-400 font-medium leading-relaxed">
                                <%= order.shippingAddress.street %>,<br>
                                <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Update Status -->
                <div class="bg-white p-10 rounded-[2.5rem] border border-zinc-100 shadow-sm">
                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-8">Management</h3>
                    
                    <form action="/owners/orders/<%= order._id %>/status" method="post" class="space-y-4">
                        <label class="text-[10px] font-black uppercase text-zinc-400 px-1">Update Status Flow</label>
                        <div class="relative">
                            <select name="orderStatus" class="w-full px-6 py-4 bg-zinc-100 border-none rounded-2xl text-xs font-black uppercase tracking-widest focus:ring-2 focus:ring-black outline-none transition-all appearance-none">
                                <option value="placed" <%= order.orderStatus === "placed" ? "selected" : "" %>>Placed</option>
                                <option value="packed" <%= order.orderStatus === "packed" ? "selected" : "" %>>Packed</option>
                                <option value="shipped" <%= order.orderStatus === "shipped" ? "selected" : "" %>>Shipped</option>
                                <option value="delivered" <%= order.orderStatus === "delivered" ? "selected" : "" %>>Delivered</option>
                                <option value="cancelled" <%= order.orderStatus === "cancelled" ? "selected" : "" %>>Cancelled</option>
                            </select>
                            <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-zinc-400">▼</div>
                        </div>
                        <button class="w-full py-5 bg-blue-600 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl shadow-blue-500/10 hover:bg-blue-700 transition-all active:scale-95">
                            Apply Changes
                        </button>
                    </form>
                </div>

                <!-- Action Bar -->
                <div class="grid grid-cols-2 gap-4">
                    <button class="py-4 bg-zinc-100 rounded-2xl text-[10px] font-black uppercase tracking-widest text-zinc-500 hover:bg-zinc-200 transition-all">Print Invoice</button>
                    <button class="py-4 bg-zinc-100 rounded-2xl text-[10px] font-black uppercase tracking-widest text-zinc-500 hover:bg-zinc-200 transition-all">Support Chat</button>
                </div>
            </div>
        </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
