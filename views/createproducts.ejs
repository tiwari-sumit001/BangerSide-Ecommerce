<%- include('partials/header') %>

<% if (error && error.length > 0) { %>
  <div class="absolute top-5 left-1/2 -translate-x-1/2 p-3 rounded-md bg-red-500">
    <span class="text-white"><%= error %></span>
  </div>
<% } %>

<% if (success && success.length > 0) { %>
  <div class="absolute top-5 left-1/2 -translate-x-1/2 p-3 rounded-md bg-blue-500">
    <span class="text-white"><%= success %></span>
  </div>
<% } %>

<div class="min-h-screen bg-zinc-50 flex font-['Outfit']">
  <!-- Admin Sidebar -->
  <div class="w-1/5 bg-white border-r border-zinc-200 p-10 flex flex-col justify-between sticky top-0 h-screen">
    <div>
        <div class="flex items-center gap-3 mb-12">
            <div class="w-10 h-10 bg-black rounded-2xl flex items-center justify-center text-white font-bold italic shadow-lg shadow-black/20">S.</div>
            <h2 class="font-black text-xl tracking-tighter">BANGER SIDE.ADMIN</h2>
        </div>
        
        <nav class="space-y-2">
            <a href="/owners/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Dashboard</span>
            </a>
            <a href="/owners/admin" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-bold bg-black text-white shadow-xl shadow-black/10">
                <span>Create New Product</span>
            </a>
            <a href="/owners/products" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Manage Inventory</span>
            </a>
            <a href="/owners/orders" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Orders Log</span>
            <a href="/owners/coupons" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Coupon Codes</span>
            </a>
        </nav>
    </div>

    <a href="/owners/logout" class="px-4 py-3 rounded-2xl text-sm font-bold text-rose-500 hover:bg-rose-50 transition-all">
        Logout System
    </a>
  </div>

  <!-- Main Content -->
  <div class="flex-1 p-16">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h1 class="text-4xl font-black text-zinc-900 tracking-tight">Create Product</h1>
                <p class="text-zinc-400 mt-2">Add a new item to your global storefront.</p>
            </div>
            <a href="/shop" target="_blank" class="px-6 py-3 bg-zinc-200 rounded-2xl text-xs font-bold hover:bg-zinc-300 transition-all">PREVIEW STORE</a>
        </div>

        <form action="/products/create" method="POST" enctype="multipart/form-data" class="space-y-8 pb-20">
            <!-- Section 1: Visuals -->
            <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-zinc-100">
                <h3 class="text-sm font-black uppercase tracking-widest text-zinc-400 mb-8 flex items-center gap-2">
                    <span class="w-2 h-2 bg-black rounded-full"></span> 01. Visual Assets
                </h3>
                
                <div class="relative group">
                    <input type="file" name="images" id="imageInput" class="hidden" multiple required onchange="previewImages(this)">
                    <label for="imageInput" class="w-full min-h-[16rem] bg-zinc-50 rounded-[2rem] border-2 border-dashed border-zinc-200 flex flex-col items-center justify-center cursor-pointer group-hover:border-black group-hover:bg-zinc-100 transition-all overflow-hidden relative">
                        <div id="uploadPlaceholder" class="flex flex-col items-center">
                            <div class="w-16 h-16 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                <span class="text-2xl">📸</span>
                            </div>
                            <p class="font-bold text-zinc-900">Upload Angle Shots (Max 5)</p>
                            <p class="text-xs text-zinc-400 mt-1">PNG, JPG, WEBP (High Res)</p>
                        </div>
                        <div id="imagePreviewContainer" class="hidden absolute inset-0 bg-white flex gap-2 p-4 overflow-x-auto no-scrollbar">
                            <!-- Previews injected here -->
                        </div>
                    </label>
                </div>
            </div>

            <script>
                function previewImages(input) {
                    const container = document.getElementById('imagePreviewContainer');
                    const placeholder = document.getElementById('uploadPlaceholder');

                    container.innerHTML = '';

                    if (input.files && input.files.length > 0) {
                        placeholder.classList.add('hidden');
                        container.classList.remove('hidden');

                        Array.from(input.files).slice(0, 5).forEach((file, index) => {
                            const reader = new FileReader();
                            reader.onload = function(e) {
                                const wrapper = document.createElement('div');
                                wrapper.className = "w-32 h-full bg-zinc-50 rounded-2xl overflow-hidden shrink-0 relative border border-zinc-100";
                                wrapper.innerHTML = `
                                    <img src="${e.target.result}" class="w-full h-full object-cover">
                                    <div class="absolute bottom-0 left-0 right-0 bg-black/60 backdrop-blur-md py-1 px-2 text-center">
                                        <span class="text-[8px] text-white font-black uppercase">Angle ${index + 1}</span>
                                    </div>
                                `;
                                container.appendChild(wrapper);
                            }
                            reader.readAsDataURL(file);
                        });
                    }
                }
            </script>

            <!-- Section 2: Core Details -->
            <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-zinc-100">
                <h3 class="text-sm font-black uppercase tracking-widest text-zinc-400 mb-8 flex items-center gap-2">
                    <span class="w-2 h-2 bg-black rounded-full"></span> 02. Product Identity
                </h3>

                <div class="grid grid-cols-2 gap-6">
                    <div class="col-span-2">
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Product Name</label>
                        <input type="text" name="name" placeholder="e.g. Midnight Oversized Tee" class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all">
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Category</label>
                        <input type="text" name="category" placeholder="T-Shirts, Hoodies..." class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all">
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Gender Focus</label>
                        <select name="gender" class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all appearance-none">
                            <option value="Unisex">Unisex</option>
                            <option value="Men">Men</option>
                            <option value="Women">Women</option>
                        </select>
                    </div>

                    <div class="col-span-2">
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-4 px-1">Available Sizes</label>
                        <div class="flex gap-4">
                            <% ["XS", "S", "M", "L", "XL", "XXL"].forEach(size => { %>
                                <label class="group relative cursor-pointer">
                                    <input type="checkbox" name="sizes" value="<%= size %>" class="hidden peer" checked>
                                    <div class="w-14 h-14 bg-zinc-50 rounded-2xl flex items-center justify-center font-bold text-xs text-zinc-400 border border-transparent peer-checked:bg-black peer-checked:text-white peer-checked:shadow-lg transition-all">
                                        <%= size %>
                                    </div>
                                </label>
                            <% }) %>
                        </div>
                    </div>

                    <div class="col-span-2">
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Description</label>
                        <textarea name="description" rows="4" placeholder="Describe the fit, fabric and feel..." class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all"></textarea>
                    </div>
                </div>
            </div>

            <!-- Section 3: Pricing & Inventory -->
            <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-zinc-100">
                <h3 class="text-sm font-black uppercase tracking-widest text-zinc-400 mb-8 flex items-center gap-2">
                    <span class="w-2 h-2 bg-black rounded-full"></span> 03. Commercials
                </h3>

                <div class="grid grid-cols-3 gap-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Base Price (₹)</label>
                        <input type="number" name="price" placeholder="0.00" class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Discount (₹)</label>
                        <input type="number" name="discount" placeholder="0.00" class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Initial Stock</label>
                        <input type="number" name="quantity" placeholder="100" class="w-full px-6 py-4 bg-zinc-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-black outline-none transition-all">
                    </div>
                </div>
            </div>

            <!-- Section 4: Theme Customization -->
            <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-zinc-100">
                <h3 class="text-sm font-black uppercase tracking-widest text-zinc-400 mb-8 flex items-center gap-2">
                    <span class="w-2 h-2 bg-black rounded-full"></span> 04. Card Aesthetic
                </h3>

                <div class="grid grid-cols-3 gap-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">BG Color</label>
                        <input type="color" name="bgColor" value="#f3f4f6" class="w-full h-14 bg-zinc-50 border-none rounded-2xl p-1 cursor-pointer">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Panel Color</label>
                        <input type="color" name="panelColor" value="#1f2937" class="w-full h-14 bg-zinc-50 border-none rounded-2xl p-1 cursor-pointer">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase text-zinc-400 mb-2 px-1">Text Color</label>
                        <input type="color" name="textColor" value="#ffffff" class="w-full h-14 bg-zinc-50 border-none rounded-2xl p-1 cursor-pointer">
                    </div>
                </div>
            </div>

            <button type="submit" class="w-full bg-black text-white py-6 rounded-[2rem] font-black text-lg shadow-2xl shadow-black/20 hover:-translate-y-1 active:scale-95 transition-all uppercase tracking-widest">
                Deploy Product to Store
            </button>
        </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
