<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-center justify-center bg-zinc-50 font-['Outfit']">
    <div class="w-full max-w-md p-10 bg-white rounded-[2.5rem] shadow-2xl border border-zinc-100 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-purple-500/10 rounded-full blur-3xl"></div>

        <div class="relative z-10 text-center">
            <div class="w-20 h-20 bg-black text-white rounded-[2rem] flex items-center justify-center mx-auto mb-8 shadow-2xl shadow-black/20">
                <i class="ri-shield-check-line text-4xl"></i>
            </div>

            <h2 class="text-3xl font-black text-zinc-900 mb-2 uppercase italic tracking-tighter">Identity <span class="text-blue-600">Verification</span></h2>
            <p class="text-zinc-400 text-xs mb-8 leading-relaxed font-medium uppercase tracking-widest">
                Enter the security code sent to <br> 
                <span class="text-black font-black mt-1 block"><%= contact %></span>
            </p>

            <% if (error && error.length > 0) { %>
                <div class="mb-6 bg-rose-50 text-rose-500 px-4 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-rose-100">
                    <%= error %>
                </div>
            <% } %>

            <form action="/users/login-otp-verify" method="post" class="space-y-6">
                <input type="hidden" name="contact" value="<%= contact %>">
                
                <div class="relative group">
                    <input type="text" name="otp" placeholder="••••••" 
                        class="w-full px-6 py-6 bg-zinc-50 border-none rounded-3xl text-center text-3xl font-black tracking-[0.8em] focus:ring-4 focus:ring-blue-600/10 outline-none transition-all placeholder:text-zinc-200"
                        maxlength="6" required autofocus autocomplete="one-time-code">
                </div>

                <button class="w-full bg-black text-white py-6 rounded-3xl font-black text-xs shadow-2xl shadow-black/20 hover:bg-blue-600 hover:-translate-y-1 active:scale-95 transition-all uppercase tracking-[0.3em]">
                    Verify Identity
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-zinc-50">
                <p class="text-zinc-400 text-[10px] font-black uppercase tracking-widest">
                    Didn't receive code? 
                    <a href="/" class="text-blue-600 hover:underline ml-1">Go Back</a>
                </p>
            </div>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>
