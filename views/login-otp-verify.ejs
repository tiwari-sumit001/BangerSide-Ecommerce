<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-center justify-center bg-zinc-50 font-['Outfit']">
    <div class="w-full max-w-md p-10 bg-white rounded-[2.5rem] shadow-2xl border border-zinc-100 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-purple-500/10 rounded-full blur-3xl"></div>

        <div class="relative z-10 text-center">
            <div class="w-20 h-20 bg-blue-50 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-sm">
                <span class="text-3xl">📱</span>
            </div>

            <h2 class="text-3xl font-black text-zinc-900 mb-2">Verify Phone</h2>
            <p class="text-zinc-400 text-sm mb-8 leading-relaxed">
                Enter the 6-digit code sent to <br> 
                <span class="text-black font-bold">+91 <%= contact %></span>
            </p>

            <% if (error && error.length > 0) { %>
                <div class="mb-6 bg-rose-50 text-rose-500 px-4 py-3 rounded-2xl text-xs font-bold border border-rose-100">
                    <%= error %>
                </div>
            <% } %>

            <form action="/users/login-otp-verify" method="post" class="space-y-6">
                <input type="hidden" name="contact" value="<%= contact %>">
                
                <div class="flex justify-between gap-2">
                    <input type="text" name="otp" placeholder="Enter 6-digit OTP" 
                        class="w-full px-6 py-5 bg-zinc-50 border-none rounded-2xl text-center text-2xl font-black tracking-[0.5em] focus:ring-2 focus:ring-black outline-none transition-all"
                        maxlength="6" required autofocus>
                </div>

                <button class="w-full bg-black text-white py-5 rounded-2xl font-black text-sm shadow-xl shadow-black/10 hover:-translate-y-1 active:scale-95 transition-all uppercase tracking-widest">
                    Verify & Login
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-zinc-50">
                <p class="text-zinc-400 text-xs">
                    Didn't receive code? 
                    <a href="/" class="text-black font-bold hover:underline ml-1">Try again</a>
                </p>
            </div>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>
