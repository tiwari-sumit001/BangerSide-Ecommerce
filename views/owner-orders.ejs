<%- include('partials/header') %>

<div class="min-h-screen bg-zinc-50 flex font-['Outfit']">
  <!-- Admin Sidebar -->
  <div class="w-1/5 bg-white border-r border-zinc-200 p-10 flex flex-col justify-between sticky top-0 h-screen">
    <div>
        <div class="flex items-center gap-3 mb-12">
            <div class="w-10 h-10 bg-black rounded-2xl flex items-center justify-center text-white font-bold italic shadow-lg shadow-black/20">S.</div>
            <h2 class="font-black text-xl tracking-tighter">BANGER SIDE.ADMIN</h2>
        </div>
        
        <nav class="space-y-2">
            <a href="/owners/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Dashboard</span>
            </a>
            <a href="/owners/admin" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Create New Product</span>
            </a>
            <a href="/owners/products" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Manage Inventory</span>
            </a>
            <a href="/owners/orders" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-bold bg-black text-white shadow-xl shadow-black/10">
                <span>Orders Log</span>
            </a>
            <a href="/owners/coupons" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Coupon Codes</span>
            </a>
        </nav>
    </div>

    <a href="/owners/logout" class="px-4 py-3 rounded-2xl text-sm font-bold text-rose-500 hover:bg-rose-50 transition-all">
        Logout System
    </a>
  </div>

  <!-- Main Content -->
  <div class="flex-1 p-16">
    <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h1 class="text-4xl font-black text-zinc-900 tracking-tight">Orders Log</h1>
                <p class="text-zinc-400 mt-2">Manage customer fulfillment and order states.</p>
            </div>
        </div>

        <% if (success && success.length > 0) { %>
            <div class="mb-8 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 px-6 py-4 rounded-2xl text-center font-medium">
                <%= success %>
            </div>
        <% } %>

        <% if (orders.length === 0) { %>
            <div class="bg-white rounded-[3rem] p-20 text-center border border-zinc-100 shadow-sm">
                <div class="text-6xl mb-6">📑</div>
                <h3 class="text-xl font-bold text-zinc-900 mb-2">No orders yet</h3>
                <p class="text-zinc-400">Orders placed by customers will appear here.</p>
            </div>
        <% } %>

        <div class="space-y-10">
            <% orders.forEach(function(order) { %>
                <div class="bg-white rounded-[2.5rem] border border-zinc-100 shadow-sm hover:shadow-2xl hover:shadow-black/5 transition-all duration-500 overflow-hidden">
                    <!-- Order Header -->
                    <div class="p-10 border-b border-zinc-50 flex items-center justify-between bg-zinc-50/30">
                        <div class="flex items-center gap-6">
                            <div class="w-16 h-16 bg-white rounded-3xl flex flex-col items-center justify-center shadow-sm">
                                <span class="text-[10px] font-black text-zinc-300 uppercase">Order</span>
                                <span class="text-xs font-black text-black">#<%= order._id.toString().slice(-6).toUpperCase() %></span>
                            </div>
                            <div>
                                <h3 class="font-black text-lg text-zinc-900 uppercase tracking-widest"><%= order.shippingAddress.fullName %></h3>
                                <p class="text-xs text-zinc-400 font-medium">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN', {day: '2-digit', month: 'short', year: 'numeric'}) %> at <%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="px-4 py-2 bg-black text-white rounded-full text-[10px] font-black uppercase tracking-widest">
                                <%= order.orderStatus %>
                            </span>
                            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest mt-3"><%= order.paymentMethodLabel %> | <%= order.paymentStatusLabel %></p>
                        </div>
                    </div>

                    <div class="p-10 grid grid-cols-2 gap-12">
                        <!-- Items -->
                        <div>
                            <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-6">Order Items (<%= order.items.length %>)</h4>
                            <div class="space-y-4">
                                <% order.items.forEach(function(item) { %>
                                    <div class="flex items-center justify-between p-4 bg-zinc-50 rounded-2xl">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center font-bold text-[10px] shadow-sm"><%= item.quantity %>x</div>
                                            <p class="text-sm font-bold text-zinc-900"><%= item.name %></p>
                                        </div>
                                        <p class="text-sm font-black text-black">₹<%= (item.price - item.discount) * item.quantity %></p>
                                    </div>
                                <% }) %>
                            </div>
                            <div class="mt-8 flex justify-between items-center px-4">
                                <p class="text-sm font-bold text-zinc-400 uppercase tracking-widest">Grand Total</p>
                                <p class="text-2xl font-black text-black">₹<%= order.pricing.finalAmount %></p>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div>
                            <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-6">Delivery Management</h4>
                            
                            <!-- Address -->
                            <div class="mb-8 p-6 bg-zinc-50 rounded-3xl border border-zinc-100">
                                <p class="text-xs font-bold text-zinc-900 mb-1"><%= order.shippingAddress.street %></p>
                                <p class="text-xs text-zinc-500"><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
                                <p class="text-xs font-black text-blue-600 mt-3 tracking-widest"><%= order.shippingAddress.phone %></p>
                            </div>

                            <form action="/owners/orders/<%= order._id %>/status" method="post" class="space-y-4">
                                <div class="relative">
                                    <select name="orderStatus" class="w-full px-6 py-4 bg-zinc-900 text-white border-none rounded-2xl text-xs font-black uppercase tracking-widest focus:ring-2 focus:ring-zinc-500 outline-none transition-all appearance-none">
                                        <option value="placed" <%= order.orderStatus === "placed" ? "selected" : "" %>>Placed</option>
                                        <option value="packed" <%= order.orderStatus === "packed" ? "selected" : "" %>>Packed</option>
                                        <option value="shipped" <%= order.orderStatus === "shipped" ? "selected" : "" %>>Shipped</option>
                                        <option value="delivered" <%= order.orderStatus === "delivered" ? "selected" : "" %>>Delivered</option>
                                        <option value="cancelled" <%= order.orderStatus === "cancelled" ? "selected" : "" %>>Cancelled</option>
                                    </select>
                                    <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-zinc-500">▼</div>
                                </div>
                                <button class="w-full py-4 bg-blue-600 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl shadow-blue-500/10 hover:bg-blue-700 transition-all active:scale-95">
                                    Update Status
                                </button>
                            </form>

                            <a href="/owners/orders/<%= order._id %>" class="w-full mt-4 flex items-center justify-center py-4 bg-zinc-100 text-zinc-600 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-zinc-200 transition-all">
                                Full Breakdown ↗
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
