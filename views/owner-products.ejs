<%- include('partials/header') %>

<div class="min-h-screen bg-zinc-50 flex font-['Outfit']">
  <!-- Admin Sidebar -->
  <div class="w-1/5 bg-white border-r border-zinc-200 p-10 flex flex-col justify-between sticky top-0 h-screen">
    <div>
        <div class="flex items-center gap-3 mb-12">
            <div class="w-10 h-10 bg-black rounded-2xl flex items-center justify-center text-white font-bold italic shadow-lg shadow-black/20">S.</div>
            <h2 class="font-black text-xl tracking-tighter">BANGER SIDE.ADMIN</h2>
        </div>
        
        <nav class="space-y-2">
            <a href="/owners/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Dashboard</span>
            </a>
            <a href="/owners/admin" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Create New Product</span>
            </a>
            <a href="/owners/products" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-bold bg-black text-white shadow-xl shadow-black/10">
                <span>Manage Inventory</span>
            </a>
            <a href="/owners/orders" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Orders Log</span>
            </a>
            <a href="/owners/coupons" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold text-zinc-500 hover:bg-zinc-100 hover:text-black transition-all">
                <span>Coupon Codes</span>
            </a>
        </nav>
    </div>

    <a href="/owners/logout" class="px-4 py-3 rounded-2xl text-sm font-bold text-rose-500 hover:bg-rose-50 transition-all">
        Logout System
    </a>
  </div>

  <!-- Main Content -->
  <div class="flex-1 p-16">
    <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h1 class="text-4xl font-black text-zinc-900 tracking-tight">Inventory</h1>
                <p class="text-zinc-400 mt-2">Oversee and manage your product catalog.</p>
            </div>
            <a href="/owners/admin" class="px-8 py-4 bg-black text-white rounded-[2rem] text-sm font-black shadow-2xl shadow-black/20 hover:-translate-y-1 active:scale-95 transition-all uppercase tracking-widest">+ NEW ITEM</a>
        </div>

        <% if (success && success.length > 0) { %>
            <div class="mb-8 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 px-6 py-4 rounded-2xl text-center font-medium">
                <%= success %>
            </div>
        <% } %>

        <% if (error && error.length > 0) { %>
            <div class="mb-8 bg-rose-500/10 border border-rose-500/20 text-rose-600 px-6 py-4 rounded-2xl text-center font-medium">
                <%= error %>
            </div>
        <% } %>

        <% if (products.length === 0) { %>
            <div class="bg-white rounded-[3rem] p-20 text-center border border-zinc-100 shadow-sm">
                <div class="text-6xl mb-6">📦</div>
                <h3 class="text-xl font-bold text-zinc-900 mb-2">Inventory Empty</h3>
                <p class="text-zinc-400 mb-8">Start adding products to populate your store.</p>
                <a href="/owners/admin" class="text-blue-600 font-bold hover:underline">Launch First Product</a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-2 gap-10">
                <% products.forEach(function(product) { %>
                    <div class="group bg-white rounded-[2.5rem] border border-zinc-100 p-8 flex gap-8 hover:shadow-2xl hover:shadow-black/5 transition-all duration-500 relative overflow-hidden">
                        <!-- Product Preview -->
                        <div class="w-40 h-48 bg-zinc-50 rounded-3xl flex items-center justify-center overflow-hidden shrink-0"
                            style="background-color: <%= product.bgcolor %>">
                            <% if (product.image) { %>
                                <img src="data:image/jpeg;base64, <%= product.image.toString('base64') %>" class="h-full w-full object-cover">
                            <% } %>
                        </div>

                        <!-- Info -->
                        <div class="flex-1 flex flex-col justify-between py-2">
                            <div>
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="px-3 py-1 bg-zinc-100 rounded-full text-[10px] font-black uppercase text-zinc-500 tracking-wider"><%= product.gender %></span>
                                    <span class="px-3 py-1 bg-zinc-100 rounded-full text-[10px] font-black uppercase text-zinc-500 tracking-wider"><%= product.category %></span>
                                </div>
                                <h3 class="text-xl font-bold text-zinc-900 leading-tight mb-1"><%= product.name %></h3>
                                <p class="text-xs text-zinc-400 font-medium line-clamp-1"><%= product.description %></p>
                            </div>

                            <div class="flex items-end justify-between">
                                <div>
                                    <p class="text-2xl font-black text-black">₹<%= product.price %></p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <div class="w-1.5 h-1.5 <%= product.quantity > 10 ? 'bg-emerald-500' : 'bg-rose-500' %> rounded-full"></div>
                                        <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest"><%= product.quantity %> units in stock</p>
                                    </div>
                                </div>

                                <div class="flex gap-2">
                                    <a href="/owners/products/<%= product._id %>/edit" class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center hover:bg-black hover:text-white transition-all shadow-sm">
                                        <span class="text-lg">✎</span>
                                    </a>
                                    <form action="/products/delete/<%= product._id %>" method="post" onsubmit="return confirm('Archive this product permanently?')">
                                        <button class="w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center text-rose-500 hover:bg-rose-500 hover:text-white transition-all shadow-sm">
                                            <span class="text-lg">×</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
