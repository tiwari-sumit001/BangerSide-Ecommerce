<%- include('./partials/header') %>

<div class="flex items-center justify-center h-screen">
  <form action="/owners/login" method="post" class="bg-white shadow-lg rounded-lg p-8 w-full max-w-md">
    <% if (error && error.length > 0) { %>
      <div class="mb-4 rounded-md bg-red-500 px-4 py-2 text-white">
        <%= error %>
      </div>
    <% } %>

    <h1 class="text-2xl font-semibold mb-6">Owner Login</h1>

    <input class="block mb-3 p-2 border w-full" type="email" name="email" placeholder="Email">
    <input class="block mb-3 p-2 border w-full" type="password" name="password" placeholder="Password">

    <button class="px-4 py-2 bg-blue-500 text-white rounded-md">
      Login
    </button>
  </form>
</div>

<%- include('./partials/footer') %>
