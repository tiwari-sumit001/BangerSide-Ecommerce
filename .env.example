# Core
JWT_KEY=your_strong_random_jwt_secret_min_32_chars
EXPRESS_SESSION_SECRET=your_strong_random_session_secret
NODE_ENV=production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bangerside

# Payments (Razorpay - razorpay.com/dashboard)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email OTP (Gmail → Security → App Passwords)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# SMS OTP (twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
